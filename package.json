{
  "name": "@zdavison/deer",
  "version": "0.7.4",
  "description": "Unattended coding agent.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "deer": "scripts/install.js"
  },
  "files": [
    "scripts/install.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test --cwd . test/",
    "lint": "oxlint src",
    "dev": "bun run src/cli.tsx",
    "build": "bun run scripts/build.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@deer/shared": "workspace:*",
    "deerbox": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "ink": "^6.0.0",
    "react": "^19.0.0",
    "react-devtools-core": "file:stubs/react-devtools-core",
    "@types/react": "^19.0.0",
    "bun-types": "latest",
    "oxlint": "latest",
    "typescript": "^5.9.3"
  }
}
